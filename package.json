{
  "name": "spectra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev:backend & npm run dev:worker & npm run dev:frontend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "dev:worker": "npm run dev:worker -w backend",
    "db:setup": "npm run db:setup -w backend",
    "build": "npm run build -w frontend",
    "start": "npm run start -w backend"
  },
    "devDependencies": {
      "@babel/core": "^7.29.7",
      "@babel/eslint-parser": "^7.29.7",
      "@babel/preset-react": "^7.29.7",
      "@eslint/js": "^10.0.1",
      "eslint": "^8.56.0",
      "eslint-config-prettier": "^10.1.8",
      "eslint-plugin-jsx-a11y": "^6.10.2",
      "eslint-plugin-prettier": "^5.5.6",
      "eslint-plugin-react": "^7.37.5",
      "globals": "^17.6.0",
      "prettier": "^3.8.3"
    },
    "eslintConfig": {
      "root": true,
      "env": {
        "browser": true,
        "node": true,
        "es2021": true
      },
      "parserOptions": {
        "ecmaVersion": 2021,
        "sourceType": "module",
        "ecmaFeatures": {
          "jsx": true
        }
      },
      "settings": {
        "react": {
          "version": "detect"
        }
      },
      "extends": [
        "eslint:recommended",
        "plugin:react/recommended",
        "plugin:jsx-a11y/recommended",
        "prettier"
      ],
      "plugins": ["react", "jsx-a11y", "prettier"],
      "rules": {
        "no-unused-vars": "off",
        "react/prop-types": "warn",
        "react/react-in-jsx-scope": "off",
        "react/jsx-uses-react": "off"
      }
    },
    "prettier": {
      "semi": true,
      "singleQuote": false,
      "tabWidth": 2,
      "trailingComma": "es5",
      "printWidth": 80
    }
}
