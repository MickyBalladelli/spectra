{
  "name": "@spectra/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon --watch src src/server.js",
    "dev:worker": "nodemon --watch src src/workers/ingestionWorker.js",
    "db:setup": "node scripts/setupDatabase.js",
    "vectors:rebuild": "node scripts/rebuildVectorStore.js",
    "worker": "node src/workers/ingestionWorker.js",
    "start": "node src/server.js"
  },
  "nodemonConfig": {
    "ignore": [
      "data/*",
      "logs/*"
    ]
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.0",
    "pdfjs-dist": "^6.0.227",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.5",
    "winston": "^3.19.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
